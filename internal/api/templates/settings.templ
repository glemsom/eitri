package templates

import "github.com/glemsom/eitri/internal/config"

templ SettingsView(cfg *config.Config, models []string, workspace string, chatPath string, currentPath string, contextWindow int) {
	@Base("Eitri — Settings", chatPath, nil, "", currentPath, workspace, contextWindow, "") {
		@SettingsForm(cfg, models, "", "", nil, "")
	}
}

templ SettingsForm(cfg *config.Config, models []string, errorMessage string, noticeMessage string, deviceFlow *CopilotDeviceFlowView, successMessage string) {
	<div id="settings-form" class="settings-view">
		if errorMessage != "" {
			@ErrorToast(errorMessage)
		}
		if successMessage != "" {
			<div class="save-success">{ successMessage }</div>
		}
		if noticeMessage != "" {
			<p class="hint">{ noticeMessage }</p>
		}
		<form hx-put="/api/config" hx-target="#settings-form" hx-swap="outerHTML">
			<details class="settings-details" open>
				<summary><span>Provider &amp; Authentication</span></summary>

				<div class="form-group">
					<label for="provider">Provider</label>
					<select id="provider" name="provider" required>
						<option value="opencode_go" if cfg.Provider == "opencode_go" { selected }>OpenCode Go</option>
						<option value="github_copilot" if cfg.Provider == "github_copilot" { selected }>GitHub Copilot</option>
						<option value="custom_openai" if cfg.Provider == "custom_openai" { selected }>Custom OpenAI (advanced/best-effort)</option>
					</select>
				</div>

				<div class={ "form-group", "base-url-group", templ.KV("base-url-hidden", cfg.Provider != "custom_openai") }>
					<label for="base_url">Base URL <span if cfg.Provider == "custom_openai" { class="required-marker" }>*</span></label>
					<input type="url" id="base_url" name="base_url" value={ cfg.BaseURL } placeholder="https://opencode.ai/zen/go" required/>
				</div>

				<div class="form-group">
					<label for="api_key">API key / token</label>
					<div class="api-key-row">
						<input type="password" id="api_key" name="api_key" value={ cfg.APIKey } placeholder="API key or bearer token" autocomplete="off"/>
						<label class="checkbox-label">
							<input type="checkbox" name="clear_api_key" value="true"/>
							Clear stored credential
						</label>
					</div>
					<small class="hint">OpenCode Go: API key required. GitHub Copilot: bearer token required. Custom OpenAI: credentials optional.</small>
				</div>

				<div class="device-flow-section">
					if deviceFlow != nil {
						<div class="device-flow-panel">
							<p>Authenticate with GitHub device flow.</p>
							<p class="device-flow-code-wrapper">Open <a href={ deviceFlow.VerificationURI } target="_blank" rel="noreferrer noopener">{ deviceFlow.VerificationURI }</a> and enter code <code class="device-flow-code">{ deviceFlow.UserCode }</code>.</p>
							<div id={ "copilot-device-flow-status-" + deviceFlow.ID } hx-get={ deviceFlow.PollURL } hx-trigger={ deviceFlow.PollTrigger } hx-target="#settings-form" hx-swap="outerHTML">
								<small class="hint">Waiting for GitHub approval…</small>
							</div>
							<div class="form-actions">
								<button type="button" hx-delete={ deviceFlow.CancelURL } hx-target="#settings-form" hx-swap="outerHTML">Cancel GitHub auth</button>
							</div>
						</div>
					} else {
						<div class="device-flow-panel">
							<div class="form-actions">
								<button type="button" hx-post="/api/providers/github_copilot/device-flow/start" hx-include="closest form" hx-target="#settings-form" hx-swap="outerHTML">Authenticate with GitHub</button>
							</div>
							<small class="hint">For GitHub Copilot. Select provider above, start device flow, then models refresh automatically.</small>
						</div>
					}
				</div>
			</details>

			<details class="settings-details">
				<summary><span>Model <span id="model-refresh-spinner" class="model-refresh-spinner" style="visibility:hidden;">&#9696;</span></span></summary>

				<div class="form-group">
					<select id="model" name="model">
						<option value="" disabled selected={ cfg.Model == "" }>Select a model...</option>
						for _, m := range models {
							<option value={ m } if cfg.Model == m { selected }>{ m }</option>
						}
					</select>
					<small class="hint">Models are discovered from current provider settings on load and save.</small>
				</div>

				<div class="form-group">
					<label for="thinking_level">Thinking Level</label>
					<select id="thinking_level" name="thinking_level">
						<option value="" if cfg.ThinkingLevel == "" { selected }>Default (off)</option>
						<option value="low" if cfg.ThinkingLevel == "low" { selected }>Low</option>
						<option value="medium" if cfg.ThinkingLevel == "medium" { selected }>Medium</option>
						<option value="high" if cfg.ThinkingLevel == "high" { selected }>High</option>
					</select>
					<small class="hint">Controls reasoning depth. Supported by DeepSeek, O-series, and other reasoning models. Requires provider support.</small>
				</div>
			</details>

			<details class="settings-details">
				<summary><span>Prompt — { len(cfg.SystemPrompt) } / 4096 chars</span></summary>

				<div class="form-group">
					<label for="system_prompt">System Prompt</label>
					<textarea id="system_prompt" name="system_prompt" class="monospace-textarea" rows="8" placeholder="Leave empty to use built-in default prompt.">{ cfg.SystemPrompt }</textarea>
					<div class="char-count-wrapper">
						<small class="char-count" id="prompt-char-count">{ len(cfg.SystemPrompt) } / 4096 chars</small>
					</div>
					<small class="hint">Applies to later runs only. Clear value to restore built-in default prompt.</small>
				</div>
			</details>

			<details class="settings-details">
				<summary><span>Timeouts &amp; Limits</span></summary>

				<div class="form-group">
					<label for="session_timeout">Session Timeout (seconds)</label>
					<input type="number" id="session_timeout" name="session_timeout" value={ cfg.SessionTimeout / 1_000_000_000 } min="60" required/>
				</div>

				<div class="form-group">
					<label for="command_timeout">Command Timeout (seconds)</label>
					<input type="number" id="command_timeout" name="command_timeout" value={ cfg.CommandTimeout / 1_000_000_000 } min="1" required/>
				</div>

				<div class="form-group">
					<label for="max_turns">Max Turns</label>
					<input type="number" id="max_turns" name="max_turns" value={ cfg.MaxTurns } min="1" required/>
				</div>

				<div class="form-group">
					<label for="context_window_tokens">Context Window Tokens</label>
					<input type="number" id="context_window_tokens" name="context_window_tokens" value={ cfg.ContextWindowTokens } min="1024" required/>
				</div>
			</details>

			<div class="form-actions form-actions-sticky">
				<button type="submit">Save</button>
				<div id="test-connection-wrapper" class="test-connection-wrapper">
					<button type="button" id="test-connection-btn" hx-get="/api/models" hx-target="#test-connection-result" hx-swap="innerHTML">Test Connection</button>
					<div id="test-connection-result" class="test-connection-result"></div>
				</div>
				<span class="save-hint">(Ctrl+Enter to save)</span>
			</div>
		</form>
	</div>
}

templ TestConnectionResult(success bool, message string) {
	if success {
		<span class="connection-ok">&#10003; { message }</span>
	} else {
		<span class="connection-err">{ message }</span>
	}
}
