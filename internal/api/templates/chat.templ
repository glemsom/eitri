package templates

import "github.com/glemsom/eitri/internal/session"

// ChatView is the main chat page for a single session.
// Renders workspace indicator, setup banner, message list, and composer.
templ ChatView(sess *session.UISession, workspace string, configValid bool) {
	<div id="chat-view">
		<div id="error-toasts"></div>
		<div id="workspace-indicator" class="workspace-indicator" title={ workspace }>
			Workspace: { pathBase(workspace) }
		</div>
		if !configValid {
			<div id="setup-banner" class="setup-banner">
				<p>Provider setup required. <a href="/settings">Open Settings</a> to configure your LLM provider.</p>
			</div>
		}
		@ActiveSkillChips(sess.ActiveSkills)
		<div class="chat-run-chrome">
			<div id="run-status" class="run-status" role="status" aria-live="polite" aria-atomic="true">
				<span id="stream-indicator" class="stream-indicator idle">Idle</span>
			</div>
			<details id="activity-panel" class="activity-panel">
				<summary>
					<span>Activity</span>
					<span id="activity-count" class="activity-count">0</span>
				</summary>
				<div id="activity-log" class="activity-log">
					<p id="activity-empty" class="text-muted">No tool activity yet.</p>
				</div>
			</details>
		</div>
		<div id="messages" class="messages">
			for _, msg := range sess.Messages {
				if msg.Role == "assistant" {
					@AssistantBubble(msg.Content)
				} else {
					@UserBubble(msg.Content)
				}
			}
			<div id="streaming" class="streaming"></div>
		</div>
		@MessageInput(sess.ID, !configValid, false)
	</div>
}

// WorkspaceIndicator shows the launch workspace path (basename) with full path in tooltip.
templ WorkspaceIndicator(workspace string) {
	<div id="workspace-indicator" class="workspace-indicator" title={ workspace }>
		Workspace: { pathBase(workspace) }
	</div>
}
