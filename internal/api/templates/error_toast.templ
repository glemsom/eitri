package templates

// ErrorToast renders an inline error banner with manual dismiss via X button.
templ ErrorToast(message string) {
	<div class="error-toast" role="alert">
		<span class="error-text">{ message }</span>
		<button class="close-btn" type="button" hx-on:click="this.closest('.error-toast').remove()">&times;</button>
	</div>
}
